# ngrok 고정 도메인 (외부망 OK, PC 껐다 켜도 주소 안 바뀜).
# PC에서: 서버(npm run start:dev) + ngrok http --url=handlebar-skype-opt.ngrok-free.dev 8080
API_BASE_URL=https://handlebar-skype-opt.ngrok-free.dev/api/v1
# 같은 와이파이 LAN: http://192.168.113.90:8080/api/v1 | 에뮬레이터: http://10.0.2.2:8080/api/v1
USE_MOCK_AUTH=false
